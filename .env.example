# CashTime Brand Concierge - environment template
# Скопируйте в .env и заполните перед локальным запуском. В Cloud Run значения
# идут из Secret Manager + переменных revision.

# --- Google Cloud / Gemini Enterprise Agent Platform ---
GOOGLE_CLOUD_PROJECT=tools-cashtimepay-com
GOOGLE_CLOUD_LOCATION=europe-west6
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Модели агента
CONCIERGE_PLANNER_MODEL=gemini-3.1-pro-preview
CONCIERGE_WORKER_MODEL=gemini-3.5-flash

# --- Gemini Enterprise Search grounding (research sub-agent RAG) ---
# Пусто → grounding работает на встроенном корпусе (offline/demo-safe).
# Заполнить именем data store после deploy/provision_grounding.sh.
GEMINI_SEARCH_DATASTORE=
GEMINI_SEARCH_LOCATION=global

# --- MCP gateway ---
MCP_BASE_URL=https://mcp.cashtimepay.com
MCP_BEARER_TOKEN=

# --- Existing CashTime services (вызываемые через MCP-обёртки) ---
AIBMR_BASE_URL=https://aibmr.internal.cashtimepay.com
AIBMO_BASE_URL=https://aibmo.internal.cashtimepay.com
AIMM_BASE_URL=https://aimm.cashtimepay.com
CREN_BASE_URL=https://cren.internal.cashtimepay.com
AICROPS_BASE_URL=https://aicrops.internal.cashtimepay.com

# Cloudflare Access (для внутренних эндпоинтов)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# --- Twenty CRM ---
TWENTY_BASE_URL=https://crm.cashtimepay.com
TWENTY_API_KEY=

# --- Сервер ---
PORT=8080
LOG_LEVEL=INFO
DEMO_MODE=false
